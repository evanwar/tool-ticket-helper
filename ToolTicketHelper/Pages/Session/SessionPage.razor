@page "/session"
@inject GlobalPhoneState PhoneState

<PageTitle>Sesión y tokens</PageTitle>

<h1 class="h4 mb-3">Sesión y generación de tokens</h1>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <p class="text-muted">Usa el teléfono global para generar un token temporal de soporte.</p>
        <button class="btn btn-primary" disabled="@(!PhoneState.HasPhoneNumber)" @onclick="GenerateToken">Generar token</button>

        @if (!string.IsNullOrWhiteSpace(_token))
        {
            <div class="alert alert-info mt-3 mb-0">
                <div class="fw-semibold">Token generado:</div>
                <code>@_token</code>
            </div>
        }
    </div>
</div>

@code {
    private string _token = string.Empty;

    private void GenerateToken()
    {
        _token = $"TK-{PhoneState.PhoneNumber}-{DateTime.UtcNow:yyyyMMddHHmmss}";
    }
}
