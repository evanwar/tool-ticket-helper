@page "/"
@inject GlobalPhoneState PhoneState

<PageTitle>Resumen</PageTitle>

<div class="mb-4">
    <h1 class="h3 mb-1">Tool Ticket Helper</h1>
    <p class="text-muted mb-0">Panel rápido para resolver tickets operativos de enrolamiento, cuenta y tarjetas.</p>
</div>

<div class="alert @(PhoneState.HasPhoneNumber ? "alert-success" : "alert-warning")" role="alert">
    @if (PhoneState.HasPhoneNumber)
    {
        <span>Teléfono activo para operaciones: <strong>@PhoneState.PhoneNumber</strong>.</span>
    }
    else
    {
        <span>Define un número de 10 dígitos en la barra superior para habilitar todas las acciones del sistema.</span>
    }
</div>

<div class="row g-3">
    <div class="col-md-6 col-xl-4">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-body">
                <h2 class="h5">Sesión y tokens</h2>
                <p class="text-muted">Genera token operativo para pruebas en Postman y herramientas internas.</p>
                <NavLink class="btn btn-primary" href="session">Ir a sesión</NavLink>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-4">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-body">
                <h2 class="h5">Cuenta</h2>
                <p class="text-muted">Consultar usuario, agregar saldo, desbloquear o eliminar cuenta.</p>
                <NavLink class="btn btn-primary" href="account">Ir a cuenta</NavLink>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-4">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-body">
                <h2 class="h5">Flujo nómina</h2>
                <p class="text-muted">Reinicia o autoriza enrolamiento N2/N4 sin borrar al usuario.</p>
                <NavLink class="btn btn-primary" href="enrollment">Ir a nómina</NavLink>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-4">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-body">
                <h2 class="h5">Tarjetas</h2>
                <p class="text-muted">Alta y baja de tarjetas asociadas al número telefónico global.</p>
                <NavLink class="btn btn-primary" href="cards">Ir a tarjetas</NavLink>
            </div>
        </div>
    </div>
</div>
